{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "api/**/*.ts",
    "lib/openrouter.ts",
    "lib/vercel-ai.ts",
    "lib/model-analytics.ts",
    "lib/redis.ts",
    "lib/utils.ts"
  ]
}
